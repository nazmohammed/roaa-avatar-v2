{
  "name": "roaa-avatar",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && python -m uvicorn app.main:app --reload --port 3001",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
